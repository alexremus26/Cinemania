<!DOCTYPE html>
<html lang="ro">

<%- include('../fragmente/head') %>

<body>
    <div id="top-anchor"></div>

    <%- include('../fragmente/header') %>

    <main id="grid-pagina">
        <section id="welcome">
            <div class="welcome-content">
                <p class="subtitlu">DESPRE CINEMANIA</p>
                <h2>Povestea noastra</h2>
                <p class="intro">
                    Cinemania este un proiect de cinema urban orientat spre experiente moderne: sali premium,
                    selectie curata de premiere si o interfata simpla pentru rezervari rapide.
                </p>
                <div class="cta-buttons">
                    <a href="/program" class="btn-main">Vezi Programul</a>
                    <a href="/" class="btn-sub">Inapoi Acasa</a>
                </div>
            </div>
            <div class="slider-mockup">
                <img src="/resurse/imagini/CinemaniaLogo.png" alt="Logo Cinemania" />
            </div>
        </section>

        <section id="anunturi">
            <h2>Misiune</h2>
            <div class="promo-box">
                <p>
                    Ne propunem sa aducem publicului filme variate, de la blockbustere la proiectii speciale,
                    intr-un spatiu confortabil si accesibil.
                </p>
            </div>
        </section>

        <section id="facilitati">
            <h2>Ce oferim</h2>
            <div class="creative-grid">
                <article class="cat-card">
                    <h3>Experienta vizuala</h3>
                    <p>Ecrane mari, sisteme audio performante si optiuni IMAX/4DX.</p>
                </article>
                <article class="cat-card">
                    <h3>Evenimente tematice</h3>
                    <p>Maratoane de film, seri retro si proiectii in avanpremiera.</p>
                </article>
                <article class="cat-card">
                    <h3>Servicii rapide</h3>
                    <p>Rezervare simpla, zone de snack si asistenta in locatie.</p>
                </article>
            </div>
        </section>
    </main>

    <%- include('../fragmente/footer') %>
</body>

</html>
